{
  "buildCommand": "npm run vercel-build",
  "outputDirectory": "build",
  "functions": {
    "api/gemini.mjs": {
      "memory": 256,
      "maxDuration": 10
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}